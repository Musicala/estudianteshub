rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function authEmail() {
      return isSignedIn() && request.auth.token.email is string
        ? request.auth.token.email
        : "";
    }

    function isBootstrapAdmin() {
      return isSignedIn() &&
        authEmail() in [
          "alekcaballeromusic@gmail.com",
          "catalina.medina.leal@gmail.com",
          "imusicala@gmail.com",
          "adminmusicala@gmail.com",
          "musicalaasesor@gmail.com"
        ];
    }

    /*
      IMPORTANTE — costo de evaluación:
      El motor de reglas tiene un límite duro de expresiones por consulta
      (~1000 en 'list'). Las versiones anteriores de estas funciones usaban
      ternarios anidados con get()/exists() repetidos y se expandían tanto
      que el motor abortaba la evaluación y NEGABA TODO a los estudiantes
      (incidente bitácoras 2026-07-02/03). Por eso aquí se usa UN solo get()
      del perfil y Map.get() con valores por defecto. Si editas estas
      funciones, mantenlas baratas.

      Nota: si users/{correo} no existe, get() falla y esa rama simplemente
      niega (los || absorben el error cuando otra rama concede). Es el mismo
      resultado que antes: sin perfil no hay acceso de estudiante.
    */
    function profileData() {
      return get(/databases/$(database)/documents/users/$(authEmail())).data;
    }

    function accessRole() {
      return profileData().get('role', '');
    }

    function accessIsActive() {
      return profileData().get('active', true) != false;
    }

    function linkedStudentIds() {
      return profileData().get('studentIds',
        profileData().get('students',
          [profileData().get('studentId',
            profileData().get('studentKey',
              profileData().get('estudianteId', '')))]));
    }

    function teacherEmailList() {
      return exists(/databases/$(database)/documents/app_config/catalogos)
        ? get(/databases/$(database)/documents/app_config/catalogos)
            .data.get('teacherAccessEmails', [])
        : [];
    }

    function isAdmin() {
      return isBootstrapAdmin() || (accessRole() == "admin" && accessIsActive());
    }

    function isTeacher() {
      return ((accessRole() == "teacher" || accessRole() == "docente") && accessIsActive()) ||
        (authEmail() != "" && authEmail() in teacherEmailList());
    }

    function isActiveStudent() {
      return accessRole() in ["student", "estudiante", "acudiente", "guardian", "parent"] &&
        accessIsActive() &&
        linkedStudentIds().size() > 0;
    }

    /*
      Sin comprobaciones "is list"/"is string": si el campo no existe, la rama
      falla sola y el || la absorbe cuando la otra concede. Acceder al campo
      directo (y no via data.get) es lo que permite al motor PROBAR las
      consultas array-contains / == de la app.
    */
    function studentOwnsBitacora() {
      return isActiveStudent() &&
        (
          resource.data.studentIds.hasAny(linkedStudentIds()) ||
          resource.data.studentId in linkedStudentIds()
        );
    }

    function studentOwnsStudentDoc() {
      return isActiveStudent() &&
        (
          resource.id in linkedStudentIds() ||
          (resource.data.studentId is string && resource.data.studentId in linkedStudentIds()) ||
          (resource.data.studentKey is string && resource.data.studentKey in linkedStudentIds()) ||
          (resource.data.estudianteId is string && resource.data.estudianteId in linkedStudentIds())
        );
    }

    function studentOwnsRoute(routeId) {
      return isActiveStudent() &&
        (
          routeId in linkedStudentIds() ||
          (resource.data.studentId is string && resource.data.studentId in linkedStudentIds()) ||
          (resource.data.studentKey is string && resource.data.studentKey in linkedStudentIds()) ||
          (resource.data.estudianteId is string && resource.data.estudianteId in linkedStudentIds())
        );
    }

    match /users/{emailKey} {
      allow read: if isAdmin() || (isSignedIn() && authEmail() == emailKey);
      allow create, update, delete: if isAdmin();
    }

    match /app_config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /bitacoras/{bitacoraId} {
      allow read: if isAdmin() || isTeacher() || studentOwnsBitacora();
      allow create, update, delete: if isAdmin() || isTeacher();
    }

    // Planeador Docente: planeaciones de clase.
    // Admin ve y gestiona todo; cada docente SOLO sus propios documentos
    // (marcados con ownerEmail == su correo).
    match /planeaciones/{planeacionId} {
      allow read, update, delete: if isAdmin() ||
        (isTeacher() && resource.data.ownerEmail == authEmail());
      allow create: if isAdmin() ||
        (isTeacher() && request.resource.data.ownerEmail == authEmail());
    }

    // Tablero de post-its del planeador (mismo criterio de propiedad).
    match /planeador_postits/{postitId} {
      allow read, update, delete: if isAdmin() ||
        (isTeacher() && resource.data.ownerEmail == authEmail());
      allow create: if isAdmin() ||
        (isTeacher() && request.resource.data.ownerEmail == authEmail());
    }

    match /student_routes/{studentId} {
      allow read: if isAdmin() || isTeacher() || studentOwnsRoute(studentId);
      allow create, update, delete: if isAdmin();
    }

    match /route_templates/{templateId} {
      allow read: if isAdmin() || isTeacher() || isActiveStudent();
      allow create, update, delete: if isAdmin();
    }

    match /student_route_progress/{routeId} {
      allow read: if isAdmin() || isTeacher() || studentOwnsRoute(routeId);
      allow create, update: if isAdmin() || isTeacher();
      allow delete: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isAdmin() || isTeacher() || studentOwnsStudentDoc();
      allow create, update, delete: if isAdmin();
    }

    // Observaciones internas privadas: SOLO equipo (admin/docente).
    // Nunca legibles por estudiantes/acudientes para evitar filtraciones.
    match /student_private_notes/{studentId} {
      allow read: if isAdmin() || isTeacher();
      allow create, update, delete: if isAdmin() || isTeacher();
    }

    match /student_comments/{commentId} {
      allow read: if isAdmin() || isTeacher() || isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isTeacher();
    }

    match /student_evidence/{evidenceId} {
      allow read: if isAdmin() || isTeacher() || isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isTeacher();
    }

    // Diario de práctica — el estudiante gestiona sus propios registros
    match /practice_logs/{logId} {
      allow read: if isAdmin() || isTeacher() ||
        (isActiveStudent() && resource.data.studentId in linkedStudentIds());
      allow create: if isActiveStudent() &&
        request.resource.data.studentId in linkedStudentIds();
      allow update: if isAdmin() || isTeacher() ||
        (isActiveStudent() && resource.data.studentId in linkedStudentIds());
      allow delete: if isAdmin() ||
        (isActiveStudent() && resource.data.studentId in linkedStudentIds());
    }

    // Mensajes estudiante ↔ docente
    match /student_messages/{studentId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.teacherEmail == authEmail()) ||
        (isActiveStudent() && studentId in linkedStudentIds());
      allow create: if isAdmin() || (isActiveStudent() &&
        studentId in linkedStudentIds() &&
        request.resource.data.studentId == studentId &&
        request.resource.data.teacherEmail is string &&
        request.resource.data.teacherEmail != "");
      allow update: if isAdmin() ||
        (isActiveStudent() && studentId in linkedStudentIds() &&
          request.resource.data.studentId == studentId &&
          request.resource.data.teacherEmail is string &&
          request.resource.data.teacherEmail != "") ||
        (isSignedIn() && resource.data.teacherEmail == authEmail() &&
          request.resource.data.teacherEmail == authEmail());
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read: if isAdmin() ||
          (isSignedIn() &&
            get(/databases/$(database)/documents/student_messages/$(studentId)).data.teacherEmail == authEmail()) ||
          (isActiveStudent() && studentId in linkedStudentIds());
        allow create: if
          request.resource.data.studentId == studentId &&
          request.resource.data.teacherEmail ==
            get(/databases/$(database)/documents/student_messages/$(studentId)).data.teacherEmail &&
          (isAdmin() ||
            (isSignedIn() && request.resource.data.senderRole == "teacher" &&
              request.resource.data.teacherEmail == authEmail()) ||
            (isActiveStudent() && studentId in linkedStudentIds() &&
              request.resource.data.senderRole == "student"));
        allow update: if isAdmin() ||
          (isSignedIn() &&
            get(/databases/$(database)/documents/student_messages/$(studentId)).data.teacherEmail == authEmail()) ||
          (isActiveStudent() && studentId in linkedStudentIds() &&
            resource.data.senderRole == "teacher");
        allow delete: if isAdmin();
      }
    }

    match /teacher_directory/{teacherEmail} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
