rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function authEmail() {
      return isSignedIn() && request.auth.token.email is string
        ? request.auth.token.email.lower()
        : "";
    }

    /*
      IMPORTANTE — costo de evaluación:
      El motor de reglas tiene un límite duro de expresiones por consulta
      (~1000 en 'list'). Las versiones anteriores de estas funciones usaban
      ternarios anidados con get()/exists() repetidos y se expandían tanto
      que el motor abortaba la evaluación y NEGABA TODO a los estudiantes
      (incidente bitácoras 2026-07-02/03). Por eso aquí se usa UN solo get()
      del perfil y Map.get() con valores por defecto. Si editas estas
      funciones, mantenlas baratas.

      Nota: si users/{correo} no existe, get() falla y esa rama simplemente
      niega (los || absorben el error cuando otra rama concede). Es el mismo
      resultado que antes: sin perfil no hay acceso de estudiante.
    */
    function profileData() {
      return get(/databases/$(database)/documents/users/$(authEmail())).data;
    }

    function accessRole() {
      return profileData().get('role', '').lower();
    }

    function accessIsActive() {
      return profileData().get('active', true) != false;
    }

    function linkedStudentIds() {
      return profileData().get('studentIds',
        profileData().get('students',
          [profileData().get('studentId',
            profileData().get('studentKey',
              profileData().get('estudianteId', '')))]));
    }

    function isAdminRole(role) {
      return role in [
        "admin", "administrator", "administrador", "administradora",
        "administrative", "administrativo", "administrativa", "direction",
        "direccion", "dirección"
      ];
    }

    function isTeacherRole(role) {
      return role in ["teacher", "docente", "profesor", "profesora"];
    }

    function isAdmin() {
      return isSignedIn() && isAdminRole(accessRole()) && accessIsActive();
    }

    function isTeacher() {
      return isSignedIn() &&
        isTeacherRole(accessRole()) &&
        accessIsActive();
    }

    function isActiveStudent() {
      return accessRole() in ["student", "estudiante", "acudiente", "guardian", "parent"] &&
        accessIsActive() &&
        linkedStudentIds().size() > 0;
    }

    /*
      Sin comprobaciones "is list"/"is string": si el campo no existe, la rama
      falla sola y el || la absorbe cuando la otra concede. Acceder al campo
      directo (y no via data.get) es lo que permite al motor PROBAR las
      consultas array-contains / == de la app.
    */
    function studentOwnsBitacora() {
      return isActiveStudent() &&
        (
          resource.data.studentIds.hasAny(linkedStudentIds()) ||
          resource.data.studentId in linkedStudentIds()
        );
    }

    function studentOwnsStudentDoc() {
      return isActiveStudent() &&
        (
          resource.id in linkedStudentIds() ||
          (resource.data.studentId is string && resource.data.studentId in linkedStudentIds()) ||
          (resource.data.studentKey is string && resource.data.studentKey in linkedStudentIds()) ||
          (resource.data.estudianteId is string && resource.data.estudianteId in linkedStudentIds())
        );
    }

    function studentOwnsRoute(routeId) {
      return isActiveStudent() &&
        (
          routeId in linkedStudentIds() ||
          (resource.data.studentId is string && resource.data.studentId in linkedStudentIds()) ||
          (resource.data.studentKey is string && resource.data.studentKey in linkedStudentIds()) ||
          (resource.data.estudianteId is string && resource.data.estudianteId in linkedStudentIds())
        );
    }

    match /users/{emailKey} {
      allow read: if isAdmin() || (isSignedIn() && authEmail() == emailKey);
      // Los perfiles de acceso e identidad se aprovisionan solo desde backend.
      allow create, update, delete: if false;
    }

    match /app_config/{docId} {
      // Catálogos y configuración del portal son datos compartidos de la app.
      allow read: if isAdmin() || isTeacher() || isActiveStudent();
      allow write: if isAdmin();
    }

    // Agenda publicada para los clientes autenticados con perfil activo.
    // Su aprovisionamiento no se hace desde el HUB ni desde Bitácoras.
    match /events/{eventId} {
      allow read: if isAdmin() || isTeacher() || isActiveStudent();
      allow write: if false;
    }

    match /bitacoras/{bitacoraId} {
      allow read: if isAdmin() || isTeacher() || studentOwnsBitacora();
      allow create, update, delete: if isAdmin() || isTeacher();
    }

    // Planeador Docente: planeaciones de clase.
    // Admin ve y gestiona todo; cada docente SOLO sus propios documentos
    // (marcados con ownerEmail == su correo).
    match /planeaciones/{planeacionId} {
      allow read, update, delete: if isAdmin() ||
        (isTeacher() && resource.data.ownerEmail == authEmail());
      allow create: if isAdmin() ||
        (isTeacher() && request.resource.data.ownerEmail == authEmail());
    }

    // Tablero de post-its del planeador (mismo criterio de propiedad).
    match /planeador_postits/{postitId} {
      allow read, update, delete: if isAdmin() ||
        (isTeacher() && resource.data.ownerEmail == authEmail());
      allow create: if isAdmin() ||
        (isTeacher() && request.resource.data.ownerEmail == authEmail());
    }

    match /student_routes/{studentId} {
      allow read: if isAdmin() || isTeacher() || studentOwnsRoute(studentId);
      allow create, update, delete: if isAdmin();
    }

    match /route_templates/{templateId} {
      allow read: if isAdmin() || isTeacher() || isActiveStudent();
      allow create, update, delete: if isAdmin();
    }

    match /student_route_progress/{routeId} {
      allow read: if isAdmin() || isTeacher() || studentOwnsRoute(routeId);
      allow create, update: if isAdmin() || isTeacher();
      allow delete: if isAdmin();
    }

    function changedStudentFieldsAreOnly(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function changedStudentFieldsInclude(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function boundedString(value, maxLength) {
      return value is string && value.size() <= maxLength;
    }

    function validFixedPedagogicalAudit(marker) {
      return request.resource.data.updatedAt == request.time &&
        request.resource.data.updatedBy == marker;
    }

    function validActorPedagogicalAudit() {
      return request.resource.data.updatedAt == request.time &&
        boundedString(request.resource.data.updatedBy, 320) &&
        request.resource.data.updatedBy.lower() == authEmail();
    }

    /*
      El modelo actual no publica una asignacion docente canonica por email o
      UID. La autorizacion docente sigue por eso el mismo limite operativo de
      la app: solo estudiantes visibles en sus listas. Un permiso publicado
      por RIP prevalece sobre los fallbacks historicos.
    */
    function hasPublishedRipTeacherVisibility() {
      return resource.data.keys().hasAny(['rip']) &&
        resource.data.rip is map &&
        resource.data.rip.keys().hasAny(['showInTeacherLists']);
    }

    function hasPublishedTopTeacherVisibility() {
      return resource.data.keys().hasAny(['showInTeacherLists']);
    }

    function legacyTeacherVisibleStatus() {
      let legacyStatus = resource.data.get('estado',
          resource.data.get('status',
            resource.data.get('estadoActual',
              resource.data.get('studentStatus', ''))));
      let status = resource.data.keys().hasAny(['rip']) &&
          resource.data.rip is map &&
          resource.data.rip.keys().hasAny(['statusLabel']) &&
          resource.data.rip.statusLabel is string
        ? resource.data.rip.statusLabel
        : legacyStatus;
      return status is string &&
        (
          status.lower() == 'activo' ||
          status.lower().matches('^activo no registro.*') ||
          status.lower().matches('^activo en pausa.*') ||
          status.lower().matches('^inactivo en pausa [(]1-3 meses[)].*') ||
          status.lower().matches('^inactivo en pausa [(]1 a 3 meses[)].*')
        );
    }

    function teacherCanEditStudent() {
      return isTeacher() &&
        (
          (
            hasPublishedRipTeacherVisibility() &&
            resource.data.rip.showInTeacherLists == true
          ) ||
          (
            !hasPublishedRipTeacherVisibility() &&
            hasPublishedTopTeacherVisibility() &&
            resource.data.showInTeacherLists == true
          ) ||
          (
            !hasPublishedRipTeacherVisibility() &&
            !hasPublishedTopTeacherVisibility() &&
            legacyTeacherVisibleStatus()
          )
        );
    }

    function validTeacherAssignmentUpdate() {
      return changedStudentFieldsAreOnly([
          'docente', 'teacher', 'updatedAt', 'updatedBy'
        ]) &&
        changedStudentFieldsInclude(['docente', 'teacher']) &&
        boundedString(request.resource.data.docente, 160) &&
        request.resource.data.teacher == request.resource.data.docente &&
        validFixedPedagogicalAudit('profile_teacher_assignment');
    }

    function validProcessItem(item) {
      return item is map &&
        item.keys().hasAll([
          'processKey', 'arte', 'detalle', 'docente', 'label'
        ]) &&
        item.keys().hasOnly([
          'processKey', 'arte', 'detalle', 'docente', 'label'
        ]) &&
        boundedString(item.processKey, 256) &&
        item.processKey != '' &&
        boundedString(item.arte, 160) &&
        boundedString(item.detalle, 256) &&
        (item.arte != '' || item.detalle != '') &&
        boundedString(item.docente, 160) &&
        boundedString(item.label, 256) &&
        item.label != '';
    }

    function validProcessAt(items, index) {
      return items.size() <= index || validProcessItem(items[index]);
    }

    function validProcessList(items) {
      return items is list &&
        items.size() <= 15 &&
        validProcessAt(items, 0) &&
        validProcessAt(items, 1) &&
        validProcessAt(items, 2) &&
        validProcessAt(items, 3) &&
        validProcessAt(items, 4) &&
        validProcessAt(items, 5) &&
        validProcessAt(items, 6) &&
        validProcessAt(items, 7) &&
        validProcessAt(items, 8) &&
        validProcessAt(items, 9) &&
        validProcessAt(items, 10) &&
        validProcessAt(items, 11) &&
        validProcessAt(items, 12) &&
        validProcessAt(items, 13) &&
        validProcessAt(items, 14);
    }

    function validProcessesUpdate() {
      return changedStudentFieldsAreOnly([
          'processes', 'area', 'instrumento', 'programa',
          'updatedAt', 'updatedBy'
        ]) &&
        changedStudentFieldsInclude([
          'processes', 'area', 'instrumento', 'programa'
        ]) &&
        validProcessList(request.resource.data.processes) &&
        boundedString(request.resource.data.area, 160) &&
        boundedString(request.resource.data.instrumento, 256) &&
        boundedString(request.resource.data.programa, 256) &&
        (
          (
            request.resource.data.processes.size() == 0 &&
            request.resource.data.area == '' &&
            request.resource.data.instrumento == '' &&
            request.resource.data.programa == ''
          ) ||
          (
            request.resource.data.processes.size() > 0 &&
            request.resource.data.area ==
              request.resource.data.processes[0].arte &&
            request.resource.data.instrumento ==
              request.resource.data.processes[0].detalle &&
            request.resource.data.programa ==
              request.resource.data.processes[0].label
          )
        ) &&
        validActorPedagogicalAudit();
    }

    function validProfileFieldsUpdate() {
      return changedStudentFieldsAreOnly([
          'interesesMusicales', 'modalidad', 'modality',
          'updatedAt', 'updatedBy'
        ]) &&
        changedStudentFieldsInclude([
          'interesesMusicales', 'modalidad', 'modality'
        ]) &&
        (
          !changedStudentFieldsInclude(['interesesMusicales']) ||
          boundedString(request.resource.data.interesesMusicales, 2000)
        ) &&
        (
          !changedStudentFieldsInclude(['modalidad', 'modality']) ||
          (
            boundedString(request.resource.data.modalidad, 80) &&
            request.resource.data.modality == request.resource.data.modalidad
          )
        ) &&
        validActorPedagogicalAudit();
    }

    function validRepertoireItem(item) {
      return item is map &&
        item.keys().hasAll([
          'nombre', 'estado', 'prioridad', 'notas',
          'fechaInicio', 'fechaLogro'
        ]) &&
        item.keys().hasOnly([
          'nombre', 'estado', 'prioridad', 'notas',
          'fechaInicio', 'fechaLogro'
        ]) &&
        boundedString(item.nombre, 300) &&
        item.nombre != '' &&
        item.estado in ['quiere', 'proceso', 'lograda'] &&
        item.prioridad in ['alta', 'media', 'baja'] &&
        boundedString(item.notas, 4000) &&
        boundedString(item.fechaInicio, 10) &&
        boundedString(item.fechaLogro, 10) &&
        (
          item.fechaInicio == '' ||
          item.fechaInicio.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        ) &&
        (
          item.fechaLogro == '' ||
          item.fechaLogro.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        );
    }

    function validRepertoireAt(names, items, index) {
      return items.size() <= index ||
        (
          names.size() > index &&
          validRepertoireItem(items[index]) &&
          names[index] == items[index].nombre
        );
    }

    function validRepertoirePayload(names, items) {
      return names is list &&
        items is list &&
        names.size() == items.size() &&
        items.size() <= 20 &&
        names.toSet().size() == names.size() &&
        validRepertoireAt(names, items, 0) &&
        validRepertoireAt(names, items, 1) &&
        validRepertoireAt(names, items, 2) &&
        validRepertoireAt(names, items, 3) &&
        validRepertoireAt(names, items, 4) &&
        validRepertoireAt(names, items, 5) &&
        validRepertoireAt(names, items, 6) &&
        validRepertoireAt(names, items, 7) &&
        validRepertoireAt(names, items, 8) &&
        validRepertoireAt(names, items, 9) &&
        validRepertoireAt(names, items, 10) &&
        validRepertoireAt(names, items, 11) &&
        validRepertoireAt(names, items, 12) &&
        validRepertoireAt(names, items, 13) &&
        validRepertoireAt(names, items, 14) &&
        validRepertoireAt(names, items, 15) &&
        validRepertoireAt(names, items, 16) &&
        validRepertoireAt(names, items, 17) &&
        validRepertoireAt(names, items, 18) &&
        validRepertoireAt(names, items, 19);
    }

    function validRepertoireUpdate() {
      return changedStudentFieldsAreOnly([
          'repertorioEscogido', 'repertoire',
          'repertorioProceso', 'repertoireProgress',
          'updatedAt', 'updatedBy'
        ]) &&
        changedStudentFieldsInclude([
          'repertorioEscogido', 'repertoire',
          'repertorioProceso', 'repertoireProgress'
        ]) &&
        request.resource.data.repertorioEscogido ==
          request.resource.data.repertoire &&
        request.resource.data.repertorioProceso ==
          request.resource.data.repertoireProgress &&
        validRepertoirePayload(
          request.resource.data.repertorioEscogido,
          request.resource.data.repertorioProceso
        ) &&
        validFixedPedagogicalAudit('profile_repertoire');
    }

    /*
      Enruta cada request a un solo validador. Ademas de impedir payloads que
      mezclen operaciones, evita evaluar las dos listas anidadas cuando el
      cambio pertenece a otro flujo.
    */
    function validAdminPedagogicalUpdate() {
      return request.resource.data.updatedBy is string &&
        (
          request.resource.data.updatedBy == 'profile_teacher_assignment'
            ? validTeacherAssignmentUpdate()
            : request.resource.data.updatedBy == 'profile_repertoire'
              ? validRepertoireUpdate()
              : changedStudentFieldsInclude([
                    'processes', 'area', 'instrumento', 'programa'
                  ])
                ? validProcessesUpdate()
                : validProfileFieldsUpdate()
        );
    }

    function validTeacherPedagogicalUpdate() {
      return request.resource.data.updatedBy is string &&
        (
          request.resource.data.updatedBy == 'profile_repertoire'
            ? validRepertoireUpdate()
            : validProfileFieldsUpdate()
        );
    }

    match /students/{studentId} {
      allow read: if isAdmin() || isTeacher() || studentOwnsStudentDoc();

      // Solo mutaciones pedagogicas exactas; identidad, estado y finanzas no
      // aparecen en ninguna allowlist y permanecen exclusivas del backend.
      allow update: if
        (isAdmin() && validAdminPedagogicalUpdate()) ||
        (teacherCanEditStudent() && validTeacherPedagogicalUpdate());

      allow create, delete: if false;
    }

    // Propuestas creadas desde el HUB. No forman parte de las obras oficiales
    // hasta que un docente las acepta y las incorpora al proceso.
    match /student_work_suggestions/{suggestionId} {
      allow read: if isAdmin() || isTeacher() ||
        (isActiveStudent() && resource.data.studentId in linkedStudentIds());
      allow create: if isActiveStudent() &&
        request.resource.data.keys().hasOnly(['studentId', 'studentName', 'nombre', 'notas', 'estado', 'createdAt', 'updatedAt']) &&
        request.resource.data.studentId in linkedStudentIds() &&
        request.resource.data.nombre is string && request.resource.data.nombre.size() > 0 && request.resource.data.nombre.size() <= 300 &&
        request.resource.data.notas is string && request.resource.data.notas.size() <= 1000 &&
        request.resource.data.estado == 'pendiente';
      allow update, delete: if isAdmin() || isTeacher();
    }

    // Bitácora de sincronizaciones entre proyectos (escrita solo por los
    // backends via Admin SDK; el cliente únicamente puede consultarla).
    match /sync_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Observaciones internas privadas: SOLO equipo (admin/docente).
    // Nunca legibles por estudiantes/acudientes para evitar filtraciones.
    match /student_private_notes/{studentId} {
      allow read: if isAdmin() || isTeacher();
      allow create, update, delete: if isAdmin() || isTeacher();
    }

    /*
      Comentarios y evidencias: SOLO vinculados. Un estudiante/acudiente lee
      únicamente documentos cuyo studentId (o studentIds) está en su perfil;
      conocer un studentId ajeno NO concede lectura. Toda creación de un
      estudiante debe traer un studentId autorizado.
    */
    function studentOwnsLinkedDoc() {
      return isActiveStudent() && (
        resource.data.studentId in linkedStudentIds() ||
        resource.data.studentIds.hasAny(linkedStudentIds())
      );
    }

    function createHasAuthorizedStudentId() {
      return request.resource.data.studentId in linkedStudentIds();
    }

    match /student_comments/{commentId} {
      allow read: if isAdmin() || isTeacher() || studentOwnsLinkedDoc();
      allow create: if isAdmin() || isTeacher() ||
        (isActiveStudent() && createHasAuthorizedStudentId());
      allow update, delete: if isAdmin() || isTeacher();
    }

    match /student_evidence/{evidenceId} {
      allow read: if isAdmin() || isTeacher() || studentOwnsLinkedDoc();
      allow create: if isAdmin() || isTeacher() ||
        (isActiveStudent() && createHasAuthorizedStudentId());
      allow update, delete: if isAdmin() || isTeacher();
    }

    // Diario de práctica — el estudiante gestiona sus propios registros
    match /practice_logs/{logId} {
      allow read: if isAdmin() || isTeacher() ||
        (isActiveStudent() && resource.data.studentId in linkedStudentIds());
      allow create: if isActiveStudent() &&
        request.resource.data.studentId in linkedStudentIds();
      allow update: if isAdmin() || isTeacher() ||
        (isActiveStudent() &&
          resource.data.studentId in linkedStudentIds() &&
          request.resource.data.studentId == resource.data.studentId);
      allow delete: if isAdmin() ||
        (isActiveStudent() && resource.data.studentId in linkedStudentIds());
    }

    /*
      Mensajes estudiante ↔ docente. Sin condiciones repetidas: la
      pertenencia del hilo y el docente del hilo se resuelven en funciones
      compartidas (un solo get() del hilo por evaluación).
    */
    function ownsThread(studentId) {
      return isActiveStudent() && studentId in linkedStudentIds();
    }

    function threadTeacherEmail(studentId) {
      return get(/databases/$(database)/documents/student_messages/$(studentId))
        .data.teacherEmail;
    }

    function targetTeacherData(email) {
      return get(/databases/$(database)/documents/users/$(email)).data;
    }

    function isActiveTeacherEmail(email) {
      return email is string &&
        email != "" &&
        isTeacherRole(targetTeacherData(email).get('role', '').lower()) &&
        targetTeacherData(email).get('active', true) != false;
    }

    function validStudentThreadCreate(studentId) {
      return request.resource.data.keys().hasAll([
          'studentId', 'teacherEmail', 'updatedAt'
        ]) &&
        request.resource.data.keys().hasOnly([
          'studentId', 'studentName', 'teacherEmail', 'teacherName',
          'lastMessage', 'lastSenderRole', 'teacherUnread', 'studentUnread',
          'createdAt', 'updatedAt'
        ]) &&
        request.resource.data.studentId == studentId &&
        isActiveTeacherEmail(request.resource.data.teacherEmail) &&
        (!('lastSenderRole' in request.resource.data) ||
          request.resource.data.lastSenderRole == "student") &&
        (!('teacherUnread' in request.resource.data) ||
          request.resource.data.teacherUnread == true);
    }

    function threadIdentityUnchanged(studentId) {
      return resource.data.studentId == studentId &&
        request.resource.data.studentId == studentId;
    }

    function validStudentTeacherSelection(studentId) {
      return threadIdentityUnchanged(studentId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'studentName', 'teacherEmail', 'teacherName', 'updatedAt'
        ]) &&
        isActiveTeacherEmail(request.resource.data.teacherEmail);
    }

    function validStudentThreadSend(studentId) {
      return threadIdentityUnchanged(studentId) &&
        request.resource.data.teacherEmail == resource.data.teacherEmail &&
        isActiveTeacherEmail(request.resource.data.teacherEmail) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastMessage', 'lastSenderRole', 'teacherUnread', 'updatedAt'
        ]) &&
        request.resource.data.lastSenderRole == "student" &&
        request.resource.data.teacherUnread == true;
    }

    function validStudentThreadRead(studentId) {
      return threadIdentityUnchanged(studentId) &&
        request.resource.data.teacherEmail == resource.data.teacherEmail &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'studentUnread'
        ]) &&
        request.resource.data.studentUnread == false;
    }

    function validTeacherThreadSend(studentId) {
      return threadIdentityUnchanged(studentId) &&
        resource.data.teacherEmail == authEmail() &&
        request.resource.data.teacherEmail == authEmail() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastMessage', 'lastSenderRole', 'studentUnread', 'updatedAt'
        ]) &&
        request.resource.data.lastSenderRole == "teacher" &&
        request.resource.data.studentUnread == true;
    }

    function validTeacherThreadRead(studentId) {
      return threadIdentityUnchanged(studentId) &&
        resource.data.teacherEmail == authEmail() &&
        request.resource.data.teacherEmail == authEmail() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'teacherUnread'
        ]) &&
        request.resource.data.teacherUnread == false;
    }

    function validMessageCreate(studentId, senderRole) {
      return request.resource.data.keys().hasAll([
          'studentId', 'text', 'senderRole', 'senderName', 'senderEmail',
          'teacherEmail', 'read', 'createdAt'
        ]) &&
        request.resource.data.keys().hasOnly([
          'studentId', 'text', 'senderRole', 'senderName', 'senderEmail',
          'teacherEmail', 'read', 'createdAt'
        ]) &&
        request.resource.data.studentId == studentId &&
        request.resource.data.text is string &&
        request.resource.data.text != "" &&
        request.resource.data.senderRole == senderRole &&
        request.resource.data.senderEmail == authEmail() &&
        request.resource.data.teacherEmail == threadTeacherEmail(studentId) &&
        request.resource.data.read == false;
    }

    function validReadReceipt(senderRole) {
      return resource.data.senderRole == senderRole &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']) &&
        request.resource.data.read == true;
    }

    match /student_messages/{studentId} {
      allow read: if isAdmin() ||
        (isTeacher() && resource.data.teacherEmail == authEmail()) ||
        ownsThread(studentId);
      allow create: if isAdmin() ||
        (ownsThread(studentId) && validStudentThreadCreate(studentId));
      allow update: if isAdmin() ||
        (ownsThread(studentId) &&
          (validStudentTeacherSelection(studentId) ||
            validStudentThreadSend(studentId) ||
            validStudentThreadRead(studentId))) ||
        (isTeacher() &&
          (validTeacherThreadSend(studentId) ||
            validTeacherThreadRead(studentId)));
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read: if isAdmin() ||
          (isTeacher() && threadTeacherEmail(studentId) == authEmail()) ||
          ownsThread(studentId);
        allow create: if
          (isAdmin() ||
            (isTeacher() && threadTeacherEmail(studentId) == authEmail() &&
              validMessageCreate(studentId, "teacher")) ||
            (ownsThread(studentId) &&
              validMessageCreate(studentId, "student")));
        allow update: if isAdmin() ||
          (isTeacher() && threadTeacherEmail(studentId) == authEmail() &&
            validReadReceipt("student")) ||
          (ownsThread(studentId) && validReadReceipt("teacher"));
        allow delete: if isAdmin();
      }
    }

    match /teacher_directory/{teacherEmail} {
      allow read: if isAdmin() || isTeacher() || isActiveStudent();
      allow write: if false;
    }
  }
}
